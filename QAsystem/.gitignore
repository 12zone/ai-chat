HELP.md

# 主配置含密钥：仓库内只提交 application.example.yml，本地复制为 application.yml
src/main/resources/application.yml

# Local overrides — put api-key / DB password here; never commit this file
src/main/resources/application-local.yml
src/main/resources/application-local.properties

# 启动导入用的大数据 JSON（见 README）
src/main/resources/data.json
.env
.env.*

# Runtime / local DB files (e.g. Milvus lite path in app.vector-search.milvus-url)
data/
*.db

# Maven / 编译产物（双保险，子模块也会忽略）
target/
**/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties
dependency-reduced-pom.xml
.flattened-pom.xml

# JVM 崩溃转储 / 日志
hs_err_pid*
replay_pid*
*.hprof
*.log
logs/

# 临时与备份
*.tmp
*.bak
*.orig
*.swp
*~

# 操作系统
.DS_Store
Thumbs.db

# 可选：爬虫/大样本目录（若再生成也不会进库）
crawled_data/

# 可选：不提交 Cursor 工作区（需要提交规则时删掉下一行）
.cursor/
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

